{
	"name": "Welcome To Hell Kit",
	"emitLegacyScripts": false,
	"tree": {
		"$className": "DataModel",
		"ReplicatedStorage": {
			"Internal": {
				"$className": "Folder",
				"Client": { "$path": "out/client" },
				"Shared": { "$path": "out/shared" },
				"UI": { "$path": "out/ui" }
			},
			"Lib": {
				"$path": "out/lib"
			},
			"Scripts": {
				"$className": "Kit",
				"Core": {
					"$path": "out/scripts"
				}
			},
			"Packages": {
				"$path": { "optional": "roblox_packages" }
			}
		},
		"ServerScriptService": {
			"Internal": {
				"$className": "Folder",
				"Server": { "$path": "out/server" }
			},
			"Packages": {
				"$path": { "optional": "roblox_server_packages" }
			}
		}
	}
}
