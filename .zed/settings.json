{
	"project_name": "Welcome To Hell",
	"disable_ai": true,
	"languages": {
		"Luau": {
			"formatter": {
				"external": {
					"command": "stylua",
					"arguments": [
						"-"
					]
				}
			}
		}
	},
	"file_types": {
		"Luau": [
			"lua"
		],
		"JSONC": [
			".luaurc"
		]
	},
	"file_scan_exclusions": [
		// Zed
		"**/.git",
		"**/.svn",
		"**/.hg",
		"**/.jj",
		"**/CVS",
		"**/.DS_Store",
		"**/Thumbs.db",
		"**/.classpath",
		"**/.settings",
		// Welcome To Hell
		"luau_packages",
		"lune_packages",
		"out"
	],
	"lsp": {
		"discord_presence": {
			"initialization_options": {
				"details": "In Welcome To Hell"
			}
		},
		"json-language-server": {
			"settings": {
				"json": {
					"schemas": [
						{
							"fileMatch": [
								"*/.luaurc"
							],
							"url": "https://raw.githubusercontent.com/JohnnyMorganz/luau-lsp/refs/heads/main/editors/code/schemas/luaurc.json"
						},
						{
							"fileMatch": [
								"*.project.json"
							],
							"url": "https://raw.githubusercontent.com/rojo-rbx/vscode-rojo/refs/heads/master/schemas/project.template.schema.json"
						}
					]
				}
			}
		},
		"luau-lsp": {
			"settings": {
				"luau-lsp": {
					"completion": {
						"imports": {
							"enabled": true,
							"ignoreGlobs": [
								"**/.pesde/**"
							]
						}
					}
				},
				"roblox": {
					"enabled": true,
					"security_level": "none"
				},
				"fflags": {
					"enable_by_default": false,
					"enable_new_solver": true,
					"override": {}
				}
			}
		}
	}
}