{
	"name": "Welcome To Hell",
	"emitLegacyScripts": false,
	"tree": {
		"$className": "DataModel",
		"ReplicatedStorage": {
			"Core": {
				"$className": "Folder",
				"Client": {
					"$path": "src/core/client"
				},
				"Shared": {
					"$path": "src/core/shared"
				},
				"UI": {
					"$path": "src/core/ui"
				}
			},
			"Game": {
				"$className": "Folder",
				"Client": {
					"$path": "src/game/client"
				},
				"Shared": {
					"$path": "src/game/shared"
				},
				"UI": {
					"$path": "src/game/ui"
				}
			},
			"Libs": {
				"$path": "src/libs"
			},
			"Scripts": {
				"$className": "Folder",
				"Core": {
					"$path": "src/scripts"
				}
			},
			"Packages": {
				"$path": {
					"optional": "roblox_packages"
				}
			}
		},
		"ServerScriptService": {
			"Core": {
				"$className": "Folder",
				"Server": {
					"$path": "src/core/server"
				}
			},
			"Game": {
				"$className": "Folder",
				"Server": {
					"$path": "src/game/server"
				}
			},
			"Packages": {
				"$path": {
					"optional": "roblox_server_packages"
				}
			}
		}
	}
}