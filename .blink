option Casing = Camel
option TypesOutput = "src/shared/generated/net.luau"
option ServerOutput = "src/server/generated/net.luau"
option ClientOutput = "src/client/generated/net.luau"
option PromiseLibrary = "ReplicatedStorage.Packages.Promise"
option RemoteScope = "WELCOME_TO_HELL_KIT"

event rejoin {
    From: Client,
    Type: Reliable,
    Call: ManyAsync,
    Data: ()
}

function getTower {
    Yield: Promise,
    Data: (),
    Return: Instance
}

function loadMechanics {
    Yield: Promise,
    Data: (),
    Return: Instance
}

function loadDecorations {
    Yield: Promise,
    Data: (),
    Return: Instance
}

event damage {
    From: Client,
    Type: Reliable,
    Call: SingleAsync,
    Data: u8
}
