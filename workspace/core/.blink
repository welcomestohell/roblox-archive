option Casing = Camel
option TypesOutput = "./shared/generated/net.luau"
option ServerOutput = "./server/generated/net.luau"
option ClientOutput = "./client/generated/net.luau"
option PromiseLibrary = "ReplicatedStorage.Packages.Promise"
option RemoteScope = "WTH_CORE"

event patch {
    from: Server,
    type: Reliable,
    call: SingleSync,
    data: unknown,
}

function fetchAssetIds {
    yield: Promise,
    return: string[]?,
}

scope mechanics {
	enum DamageMode = { Value, Preset }
	enum DamagePreset = { Base, Doubled, Quadrupled, Lethal }
	enum DamageMeasurement = { Raw, Scaled }

	struct DamageConfiguration {
		mode: DamageMode,
	    value: i16?,
	    preset: DamagePreset?,
	    measurement: DamageMeasurement,
		asHeal: boolean?
	}

	event damage {
	    from: Client,
	    type: Unreliable,
	    call: ManyAsync,
	    data: DamageConfiguration
	}
}
