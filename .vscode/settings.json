{
    // Ai can go shit urselves
    "chat.disableAIFeatures": true,
    "chat.agent.enabled": false,
    "chat.commandCenter.enabled": false,
    "terminal.integrated.initialHint": false,
    // rest
    "editor.formatOnSave": true,
    "editor.rulers": [
        80,
        120
    ],
    "files.associations": {
        ".luaurc": "jsonc",
        ".zed/settings.json": "jsonc"
    },
    "luau-lsp.completion.showPropertiesOnMethodCall": true,
    "luau-lsp.completion.imports.separateGroupsWithLine": true,
    "luau-lsp.completion.imports.stringRequires.enabled": true,
    "luau-lsp.fflags.enableNewSolver": true,
    "luau-lsp.ignoreGlobs": [
        "**/.pesde/**",
        "out/**",
        "inspiration/**"
    ],
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/.pesde": true,
        "**/*.lock": true,
        ".venv": true,
        ".cache": true,
        ".zed": true,
        "game": true,
        "patches": true,
        "out": true,
        "site": true,
        "lune_packages": true,
        "luau_packages": true,
        "roblox_packages": true,
        "sourcemap.json": true,
    },
    "luau-lsp.platform.type": "roblox",
    "luau-lsp.types.robloxSecurityLevel": "None",
    "[luau]": {
        "editor.defaultFormatter": "JohnnyMorganz.stylua",
    },
}