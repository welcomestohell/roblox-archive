{
    "luau-lsp.fflags.enableNewSolver": true,
    "luau-lsp.platform.type": "roblox",
    "luau-lsp.completion.imports.separateGroupsWithLine": true,
    "luau-lsp.completion.imports.requireStyle": "alwaysAbsolute",
    "luau-lsp.completion.imports.stringRequires.enabled": true,
    "luau-lsp.ignoreGlobs": [
        "**/.pesde/**",
        "**/.output/**"
    ],
    "luau-lsp.completion.imports.ignoreGlobs": [
        "**/.pesde/**",
        "**/.output/**"
    ],
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/*.lock": true,
        ".pesde": true,
        "roblox_packages/.pesde": false,
        ".output": true,
        "patches": true,
        "lune_packages": true,
        "luau_packages": true,
        "default.project.json": true,
        "sourcemap.project.json": true,
        "asphalt.lock.toml": true,
    },
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "*.luau": "${capture}.story.luau, ${capture}.spec.luau"
    },
    "editor.formatOnSave": true,
    "[luau]": {
        "editor.defaultFormatter": "JohnnyMorganz.stylua"
    },
}