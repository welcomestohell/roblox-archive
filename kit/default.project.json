{
	"name": "Welcome To Hell Kit",
	"emitLegacyScripts": false,
	"tree": {
		"$className": "DataModel",
		"ReplicatedStorage": {
			"Internal": {
				"$className": "Folder",
				"Kit": {
					"$className": "Folder",
					"Client": {
						"$path": "out/kit/client"
					},
					"Shared": {
						"$path": "out/kit/shared"
					},
					"UI": {
						"$path": "out/kit/ui"
					}
				}
			},
			"Libs": {
				"$path": "out/libs"
			},
			"Scripts": {
				"$className": "Folder",
				"Core": {
					"$path": "out/kit/scripts"
				}
			},
			"Packages": {
				"$path": {
					"optional": "roblox_packages"
				}
			}
		},
		"ServerScriptService": {
			"Internal": {
				"$className": "Folder",
				"Kit": {
					"$className": "Folder",
					"Server": {
						"$path": "out/kit/server"
					}
				}
			},
			"Packages": {
				"$path": {
					"optional": "roblox_server_packages"
				}
			}
		}
	}
}